{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://echo.app/schema/season.schema.json",
  "title": "Season",
  "description": "A complete narrative arc consisting of 4 acts and 15-25 vignettes. See docs/04_Game_Design.md and docs/03_Product_Requirements.md.",
  "type": "object",
  "required": ["id", "title", "locale", "version", "acts"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^season-[0-9]{3,}$",
      "description": "Stable season identifier, e.g. 'season-001'."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "locale": {
      "type": "string",
      "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
      "description": "BCP-47 locale, e.g. 'en-GB'."
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Season content version. Increment monotonically when re-publishing."
    },
    "description": {
      "type": "string"
    },
    "acts": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "description": "Exactly four acts: Morning, Midday, Afternoon, Evening.",
      "items": {
        "$ref": "act.schema.json"
      }
    }
  }
}
